{
  "name": "hose1021.github.com",
  "version": "2.0.0",
  "author": "Mikail Huseynov <hose1021@gmail.com>",
  "private": true,
  "scripts": {
    "generate": "bun scripts/generate.js",
    "serve": "concurrently \"bun x tailwindcss --input tailwind.css --output docs/build.css --watch\" \"live-server ./docs\"",
    "build": "bun run generate && bun x tailwindcss --input tailwind.css --output docs/build.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "tailwindcss": "^4.3.0"
  }
}
